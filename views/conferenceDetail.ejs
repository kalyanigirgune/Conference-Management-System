<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= conference.title %> - Details</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/conferencedetail.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">EventEase</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                    <% if (typeof user !== "undefined" && user) { %>
                        <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link btn btn-outline-light" href="/login">Login</a></li>
                    <% } %>
                    
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-5">
        <div class="card conference-card">
            <% if (conference.imageUrl) { %>
                <img src="<%= conference.imageUrl %>" alt="<%= conference.title %>" class="card-img-top">
            <% } %>
            <div class="card-body">
                <h2 class="text-center mb-4"><%= conference.title %></h2>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Date:</strong> <%= new Date(conference.date).toDateString() %></li>
                    <li class="list-group-item"><strong>Organizer:</strong> <%= conference.organizer %></li>
                    <li class="list-group-item"><strong>Location:</strong> <%= conference.location %></li>
                    <li class="list-group-item"><strong>Type:</strong> <%= conference.type || "N/A" %></li>
                    <% if (conference.type === "paid") { %>
                        <li class="list-group-item"><strong>Amount:</strong> ₹<%= conference.amount %></li>
                    <% } %>
                    <li class="list-group-item"><strong>Deadline:</strong> <%= conference.deadline ? new Date(conference.deadline).toDateString() : "N/A" %></li>
                </ul>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <a href="/dashboard" class="btn btn-primary">Back to Dashboard</a>
        </div>
    </main>

    <%- include('partials/footer') %>

</body>
</html>
